{
  "targetApplicationNames": ["Helium"],
  "targetBundleIdentifiers": ["net.imput.helium", "app.helium", "com.imput.helium"],
  "audioSampleRate": 16000,
  "audioChannelCount": 1,
  "showChineseSource": false,
  "translatePartialResults": false,
  "asrCommand": {
    "argv": [
      ".build/debug/qwen3-asr-stdin",
      "--model-dir",
      "/Users/jianruicheng/Library/Application Support/com.jasonchien.Voco/Qwen3Models/mlx-community_Qwen3-ASR-1.7B-8bit",
      "--language",
      "auto",
      "--min-segment-seconds",
      "1.1",
      "--max-segment-seconds",
      "3.2",
      "--silence-seconds",
      "0.28"
    ]
  },
  "translatorCommand": {
    "argv": [
      "/Users/jianruicheng/GitHub/AISUBTITLE/scripts/codex-translate-lines.sh"
    ],
    "environment": {
      "AISUBTITLE_VERBOSE_LOG": "1",
      "AISUBTITLE_TRANSLATE_PROVIDER": "openrouter",
      "AISUBTITLE_TRANSLATE_DRAIN_SECONDS": "0.05",
      "AISUBTITLE_TRANSLATE_LOOKAHEAD_LINES": "1",
      "AISUBTITLE_TRANSLATE_LOOKAHEAD_MODE": "auto",
      "AISUBTITLE_TRANSLATE_LOOKAHEAD_MAX_DELAY_SECONDS": "1.2",
      "AISUBTITLE_TRANSLATE_PREVIOUS_SOURCE_CONTEXT_LINES": "2",
      "AISUBTITLE_TRANSLATE_MAX_IN_FLIGHT": "3",
      "OPENROUTER_TRANSLATE_MODEL": "google/gemini-3.1-flash-lite",
      "OPENROUTER_REASONING_EFFORT": "none"
    }
  }
}
